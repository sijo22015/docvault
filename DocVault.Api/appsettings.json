{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=docvault;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "DocVault",
    "Audience": "DocVault.Client",
    "SigningKey": "DocVault-Super-Secret-Signing-Key-Change-In-Production-32chars+",
    "AccessTokenMinutes": "15",
    "RefreshTokenDays": "7"
  },
  "Storage": {
    "Provider": "LocalDisk",
    "RootPath": "D:\\DocVault\\storage",
    "MaxFileSizeMB": "25",
    "AllowedExtensions": [ ".pdf", ".doc", ".docx", ".txt", ".jpg", ".jpeg", ".png", ".webp" ]
  },
  "Retention": {
    "SoftDeleteGraceDays": 30,
    "HardDeleteAfterYears": 7
  },
  "FYLock": {
    "DaysAfterFYEndToAllowLock": 90
  },
  "Cors": {
    "Origins": [ "http://localhost:5173", "https://docvault2026.vercel.app" ]
  },
  "Email": {
    "Smtp": {
      "Host": "smtp.example.com",
      "Port": 587,
      "User": "",
      "Pass": ""
    }
  },
  "Seed": {
    "AdminEmail": "admin@docvault.local",
    "AdminPassword": "Admin@12345"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
